<%- include('../../partials/header', { title: 'Quản lý Chi nhánh', activePage: 'branches' }) %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Cơ sở / Chi nhánh</h2>
        <p class="text-slate-500 text-sm mt-1">Quản lý mạng lưới các trung tâm FitCity trên toàn quốc</p>
    </div>
    <a href="/admin/branches/create" class="inline-flex items-center justify-center px-4 py-2 bg-lime-500 hover:bg-lime-600 text-slate-900 font-semibold rounded-lg transition-colors shadow-sm">
        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Thêm Chi Nhánh
    </a>
</div>

<!-- DATA TABLE -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <div class="w-full max-w-sm relative">
            <svg class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" placeholder="Tìm kiếm chi nhánh (Nhập tên)..." class="pl-10 pr-4 py-2 w-full border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-lime-500 focus:border-lime-500 outline-none transition-all">
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-sm uppercase tracking-wider border-b border-slate-200">
                    <th class="p-4 font-semibold">Tên Chi nhánh</th>
                    <th class="p-4 font-semibold">Địa chỉ chi tiết</th>
                    <th class="p-4 font-semibold">Hotline</th>
                    <th class="p-4 font-semibold">Quản lý Cơ sở (Manager)</th>
                    <th class="p-4 font-semibold text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(typeof branches !== 'undefined' && branches.length > 0) { %>
                    <% branches.forEach(branch => { %>
                        <tr class="hover:bg-slate-50/70 transition-colors">
                            <td class="p-4">
                                <div class="font-bold text-slate-800"><%= branch.name %></div>
                            </td>
                            <td class="p-4">
                                <div class="text-sm text-slate-600 max-w-sm truncate" title="<%= branch.address %>">
                                    <%= branch.address %>
                                </div>
                            </td>
                            <td class="p-4 text-sm font-medium text-slate-700">
                                <%= branch.phone || 'Chưa cập nhật' %>
                            </td>
                            <td class="p-4">
                                <% if(branch.manager) { %>
                                    <div class="text-sm font-medium text-blue-700"><%= branch.manager.name %></div>
                                    <div class="text-xs text-slate-500"><%= branch.manager.email %></div>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                        Chưa phân bổ
                                    </span>
                                <% } %>
                            </td>
                            <td class="p-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="/admin/branches/edit/<%= branch._id %>" class="text-slate-400 hover:text-blue-600 transition-colors" title="Chỉnh sửa">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </a>
                                    <!-- Role Protection Alert: Chỉ cho phép click xoá nếu role là Admin hoặc SA -->
                                    <form action="/admin/branches/delete/<%= branch._id %>" method="POST" class="inline-block" onsubmit="return confirm('CẢNH BÁO: Bạn chuẩn bị xoá Chi nhánh này? Thao tác có thể ảnh hưởng báo cáo Doanh Thu!');">
                                        <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors" title="Xóa">
                                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="p-8 text-center text-slate-500">
                            Chưa có dữ liệu Chi nhánh. Hãy bấm "Thêm Chi Nhánh" ở góc trên!
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../partials/footer') %>
