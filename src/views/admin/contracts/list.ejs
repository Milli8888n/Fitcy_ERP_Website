<%- include('../../partials/header', { title: 'Quản lý Thu Chi & Hợp đồng', activePage: 'contracts' }) %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Doanh thu & Hợp đồng Hội viên</h2>
        <p class="text-slate-500 text-sm mt-1">Lưu trữ hoá đơn đóng tiền, hoa hồng và theo dõi ngày hết hạn gói tập</p>
    </div>
    <a href="/admin/contracts/create" class="inline-flex items-center justify-center px-4 py-2 bg-lime-500 hover:bg-lime-600 text-slate-900 font-semibold rounded-lg transition-colors shadow-sm">
        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Ký Hợp Đồng Mới
    </a>
</div>

<!-- DATA TABLE -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-200 bg-slate-50/50 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="w-full max-w-sm relative">
            <svg class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" placeholder="Tìm kiếm theo mã Hợp đồng hoặc tên KH..." class="pl-10 pr-4 py-2 w-full border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-lime-500 focus:border-lime-500 outline-none transition-all">
        </div>
        <div class="flex gap-2">
            <span class="px-3 py-1.5 bg-emerald-100 text-emerald-800 text-xs font-bold rounded-full">Tổng tiền: <%= typeof contracts !== 'undefined' ? new Intl.NumberFormat('vi-VN').format(contracts.reduce((acc, c) => acc + (c.paidAmount || 0), 0)) : 0 %> VNĐ</span>
        </div>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-200">
                    <th class="p-4 font-semibold">Mã HĐ / Khách Hàng</th>
                    <th class="p-4 font-semibold">Dịch vụ & Gói</th>
                    <th class="p-4 font-semibold text-center">Tài chính (VNĐ)</th>
                    <th class="p-4 font-semibold text-center">Trạng thái Thanh toán</th>
                    <th class="p-4 font-semibold text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(typeof contracts !== 'undefined' && contracts.length > 0) { %>
                    <% contracts.forEach(contract => { %>
                        <tr class="hover:bg-slate-50/70 transition-colors">
                            <td class="p-4">
                                <div class="font-bold text-slate-800 font-mono text-sm flex items-center gap-1">
                                    #<%= contract._id.toString().substring(18, 24).toUpperCase() %>
                                    <% if (contract.googleDriveFileId) { %>
                                        <span class="material-symbols-outlined text-[14px] text-blue-500" title="Đã lưu trữ Cloud">cloud_done</span>
                                    <% } %>
                                </div>
                                <div class="text-sm text-slate-600 mt-1 font-medium"><%= contract.client ? contract.client.name : 'Unknown' %></div>
                            </td>
                            <td class="p-4">
                                <div class="font-bold text-slate-800 text-sm"><%= contract.servicePackage ? contract.servicePackage.name : 'N/A' %></div>
                                <div class="text-xs text-slate-500 mt-1">
                                    <span class="inline-block bg-slate-100 rounded px-1 flex items-center gap-1 w-fit">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg> 
                                        PT: <%= contract.pt ? contract.pt.name : 'Tự tập' %>
                                    </span>
                                </div>
                            </td>
                            <td class="p-4 text-center">
                                <div class="text-sm font-bold text-slate-800"><%= new Intl.NumberFormat('vi-VN').format(contract.totalAmount) %></div>
                                <% if(contract.discount > 0) { %>
                                    <div class="text-xs text-red-500">- <%= new Intl.NumberFormat('vi-VN').format(contract.discount) %></div>
                                <% } %>
                            </td>
                            <td class="p-4 text-center">
                                <!-- Status Badge -->
                                <% if(contract.paymentStatus === 'Paid') { %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">
                                        Đã thu đủ tiền
                                    </span>
                                <% } else if(contract.paymentStatus === 'Deposit') { %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-800">
                                        Đã đặt cọc
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-800">
                                        Chưa thanh toán
                                    </span>
                                <% } %>
                            </td>
                            <td class="p-4 text-center">
                                <div class="flex items-center justify-center gap-2 text-slate-400">
                                    <a href="/admin/contracts/download/<%= contract._id %>" class="hover:text-emerald-600 transition-colors bg-slate-50 p-1.5 rounded" title="Xuất PDF Hợp đồng">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                        </svg>
                                    </a>
                                    <a href="/admin/contracts/edit/<%= contract._id %>" class="hover:text-blue-600 transition-colors bg-slate-50 p-1.5 rounded" title="Điều chỉnh / Cập nhật">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </a>
                                    <% if (user && (user.role === 'SA' || (user.role === 'Admin' && contract.paymentStatus !== 'Paid'))) { %>
                                        <form action="/admin/contracts/delete/<%= contract._id %>" method="POST" class="inline-block" onsubmit="return confirm('CẢNH BÁO BÁO CÁO TÀI CHÍNH: Xoá hợp đồng này sẽ làm móp méo dữ liệu Doanh thu đang ghi nhận. Có chắc chắn xoá?');">
                                            <button type="submit" class="hover:text-red-600 transition-colors bg-slate-50 p-1.5 rounded" title="Hủy bỏ">
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="p-8 text-center text-slate-500">
                            Chưa có dữ liệu Hợp đồng trong tháng này!
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../partials/footer') %>
