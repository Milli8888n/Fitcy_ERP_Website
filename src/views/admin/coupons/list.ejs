<%- include('../../partials/header', { title: 'Mã Giảm Giá & Affiliate', activePage: 'coupons' }) %>

<div class="mb-8 flex justify-between items-center bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
    <div>
        <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Khuyến mãi & Mã giảm giá</h2>
        <p class="text-slate-500 text-sm mt-1">Quản lý các chiến dịch marketing và mã giới thiệu đại lý.</p>
    </div>
    <a href="/admin/coupons/create" class="bg-slate-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-800 transition-all shadow-lg flex items-center gap-2">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Tạo mã mới
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if(coupons && coupons.length > 0) { %>
        <% coupons.forEach(c => { %>
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-xl transition-all group">
                <div class="p-6">
                    <div class="flex justify-between items-start mb-4">
                        <div class="bg-lime-50 text-lime-700 px-3 py-1 rounded-full text-xs font-black font-mono tracking-widest uppercase">
                            #<%= c.code %>
                        </div>
                        <% if(c.usageLimit <= 0 || (c.endDate && new Date(c.endDate) < new Date())) { %>
                            <span class="text-[10px] bg-rose-50 text-rose-600 px-2 py-0.5 rounded-lg font-bold uppercase">Hết hạn</span>
                        <% } else { %>
                            <span class="text-[10px] bg-emerald-50 text-emerald-600 px-2 py-0.5 rounded-lg font-bold uppercase">Hoạt động</span>
                        <% } %>
                    </div>

                    <div class="text-3xl font-black text-slate-900 mb-1">
                        <%= c.type === 'Percentage' ? c.value + '%' : new Intl.NumberFormat('vi-VN').format(c.value) + 'đ' %>
                    </div>
                    <p class="text-slate-500 text-xs font-medium uppercase tracking-tighter">GIẢM GIÁ TRỰC TIẾP</p>

                    <div class="mt-6 space-y-3 pt-6 border-t border-slate-50">
                        <div class="flex justify-between text-xs font-medium">
                            <span class="text-slate-400 uppercase">Giới hạn sử dụng</span>
                            <span class="text-slate-800 font-bold"><%= c.usageCount %> / <%= c.usageLimit + c.usageCount %></span>
                        </div>
                        <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                            <% 
                                let totalLimit = (c.usageLimit + c.usageCount);
                                let percent = totalLimit > 0 ? (c.usageCount / totalLimit) * 100 : 0;
                            %>
                            <div class="bg-lime-500 h-full" style="width: <%= percent %>%"></div>
                        </div>
                        <div class="flex justify-between text-xs font-medium">
                            <span class="text-slate-400 uppercase">Ngày hết hạn</span>
                            <span class="text-slate-800 font-bold"><%= c.endDate ? new Date(c.endDate).toLocaleDateString('vi-VN') : 'Không' %></span>
                        </div>
                    </div>
                </div>
                
                <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-all">
                    <span class="text-[10px] text-slate-400 italic">By: <%= c.createdBy ? c.createdBy.name : 'System' %></span>
                    <a href="/admin/coupons/delete/<%= c._id %>" onclick="return confirm('Xoá mã này?')" class="text-rose-500 hover:text-rose-700">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v2m-3 7h10"></path>
                        </svg>
                    </a>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <!-- Empty State -->
        <div class="col-span-full py-20 text-center bg-white rounded-3xl border border-dashed border-slate-200">
            <svg class="mx-auto h-12 w-12 text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            <p class="text-slate-500 font-medium">Bạn chưa khởi tạo mã giảm giá nào.</p>
        </div>
    <% } %>
</div>

<%- include('../../partials/footer') %>
