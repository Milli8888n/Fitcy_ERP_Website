<%- include('../../partials/header', { title: 'Quản lý Gói tập', activePage: 'packages' }) %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Danh sách Gói tập</h2>
        <p class="text-slate-500 text-sm mt-1">Quản lý và thiết lập giá bán các dịch vụ Gym, PT, Yoga...</p>
    </div>
    <a href="/admin/packages/create" class="inline-flex items-center justify-center px-4 py-2 bg-lime-500 hover:bg-lime-600 text-slate-900 font-semibold rounded-lg transition-colors shadow-sm">
        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Tạo Gói Tập
    </a>
</div>

<!-- DATA TABLE -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <div class="w-full max-w-sm relative">
            <svg class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" placeholder="Tìm kiếm gói tập..." class="pl-10 pr-4 py-2 w-full border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-lime-500 focus:border-lime-500 outline-none transition-all">
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-sm uppercase tracking-wider border-b border-slate-200">
                    <th class="p-4 font-semibold">Tên gói</th>
                    <th class="p-4 font-semibold text-center">Loại</th>
                    <th class="p-4 font-semibold text-center">Thời hạn</th>
                    <th class="p-4 font-semibold text-center">Số buổi</th>
                    <th class="p-4 font-semibold text-right">Giá tiền (VND)</th>
                    <th class="p-4 font-semibold text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(typeof packages !== 'undefined' && packages.length > 0) { %>
                    <% packages.forEach(pkg => { %>
                        <tr class="hover:bg-slate-50/70 transition-colors">
                            <td class="p-4">
                                <div class="font-bold text-slate-800"><%= pkg.name %></div>
                                <div class="text-xs text-slate-500 truncate mt-0.5 max-w-xs"><%= pkg.description || 'Không có mô tả' %></div>
                            </td>
                            <td class="p-4 text-center">
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full 
                                    <%= pkg.type === 'Gym' ? 'bg-blue-100 text-blue-700' : 
                                       (pkg.type === 'PT' ? 'bg-amber-100 text-amber-700' : 
                                       (pkg.type === 'Yoga' ? 'bg-purple-100 text-purple-700' : 'bg-slate-100 text-slate-700')) %>">
                                    <%= pkg.type %>
                                </span>
                            </td>
                            <td class="p-4 text-center text-sm text-slate-700"><%= pkg.duration %> ngày</td>
                            <td class="p-4 text-center text-sm text-slate-700">
                                <%= pkg.sessions ? pkg.sessions + ' buổi' : 'Không giới hạn' %>
                            </td>
                            <td class="p-4 text-right font-semibold text-indigo-600">
                                <%= new Intl.NumberFormat('vi-VN').format(pkg.price) %>
                            </td>
                            <td class="p-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="/admin/packages/edit/<%= pkg._id %>" class="text-slate-400 hover:text-blue-600 transition-colors" title="Chỉnh sửa">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </a>
                                    <form action="/admin/packages/delete/<%= pkg._id %>" method="POST" class="inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn xoá gói tập này? Sẽ không thể hoàn tác đâu nhé!');">
                                        <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors" title="Xóa">
                                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="p-8 text-center text-slate-500">
                            Chưa có dữ liệu. Vui lòng tạo Gói tập đầu tiên!
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../partials/footer') %>
