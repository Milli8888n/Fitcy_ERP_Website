<%- include('../../partials/header', { title: 'Bảng lương & Hoa hồng PT/Sales', activePage: 'payroll' }) %>

<div class="mb-8 flex flex-col sm:flex-row justify-between items-end gap-4">
    <div>
        <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Thanh toán Lương & Thưởng</h2>
        <p class="text-slate-500 mt-2 flex items-center gap-2">
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Kỳ quyết toán: Tháng <%= month %> / <%= year %>
        </p>
    </div>
    
    <div class="flex gap-3">
        <a href="/admin/payroll/export-csv" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl shadow-sm text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-all flex items-center gap-2">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Xuất Báo cáo CSV
        </a>
        <button onclick="window.print()" class="px-5 py-2.5 bg-slate-900 text-white rounded-xl shadow-lg shadow-slate-200 text-sm font-bold hover:bg-slate-800 transition-all flex items-center gap-2">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
            </svg>
            In Phiếu Lương
        </button>
    </div>
</div>

<!-- Print Styles: ẩn sidebar, header nav, chỉ in nội dung bảng lương -->
<style>
    @media print {
        aside, nav, .sidebar, [class*="complementary"],
        button, a[href="/admin/payroll/export-csv"],
        .flex.gap-3 { display: none !important; }
        main { margin: 0 !important; padding: 0 !important; width: 100% !important; }
        body { background: white !important; }
        .shadow-xl, .shadow-lg, .shadow-sm { box-shadow: none !important; }
    }
</style>

<!-- KPI Cards for Payroll Overall -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-indigo-600 p-6 rounded-2xl text-white shadow-xl shadow-indigo-100 relative overflow-hidden group">
        <div class="relative z-10">
            <p class="text-indigo-100 text-xs font-bold uppercase tracking-widest opacity-80 mb-1">Dự chi Lương Cứng</p>
            <h3 class="text-2xl font-black">~<%= new Intl.NumberFormat('vi-VN').format(payrollData.length * 5000000) %> <small class="text-xs font-normal">VNĐ</small></h3>
        </div>
        <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:scale-110 transition-transform">
            <svg class="h-24 w-24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21 18v1c0 1.1-.9 2-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14c1.1 0 2 .9 2 2v1h-9a2 2 0 00-2 2v8a2 2 0 002 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"></path>
            </svg>
        </div>
    </div>
    
    <div class="bg-amber-500 p-6 rounded-2xl text-white shadow-xl shadow-amber-100 relative overflow-hidden group">
        <div class="relative z-10">
            <p class="text-amber-100 text-xs font-bold uppercase tracking-widest opacity-80 mb-1">Tổng Hoa Hồng Phát Sinh</p>
            <% 
                let totalCommission = payrollData.reduce((sum, p) => sum + p.commission, 0);
            %>
            <h3 class="text-2xl font-black"><%= new Intl.NumberFormat('vi-VN').format(totalCommission) %> <small class="text-xs font-normal">VNĐ</small></h3>
        </div>
        <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:scale-110 transition-transform">
            <svg class="h-24 w-24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"></path>
            </svg>
        </div>
    </div>

    <div class="bg-emerald-500 p-6 rounded-2xl text-white shadow-xl shadow-emerald-100 relative overflow-hidden group">
        <div class="relative z-10">
            <p class="text-emerald-100 text-xs font-bold uppercase tracking-widest opacity-80 mb-1">Tổng Ngân Sách Thực Chi</p>
            <h3 class="text-2xl font-black"><%= new Intl.NumberFormat('vi-VN').format((payrollData.length * 5000000) + totalCommission) %> <small class="text-xs font-normal">VNĐ</small></h3>
        </div>
        <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:scale-110 transition-transform">
            <svg class="h-24 w-24" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.89 11.1c-1.78-.59-2.64-.96-2.64-1.9 0-1.02 1.11-1.39 1.81-1.39 1.31 0 1.79.99 1.9 1.34l1.58-.67c-.15-.45-.82-1.92-2.54-2.16V5h-2v1.3c-2.04.45-3.05 1.87-3.05 3.22 0 1.87 1.52 2.82 3.51 3.48 1.64.54 2.29 1.14 2.29 2.02 0 1.18-1.12 1.78-2.15 1.78-1.81 0-2.35-1.45-2.48-1.85l-1.64.67C7.86 16.68 8.92 17.76 10 18.05V20h2v-1.35c1.49-.3 3.05-1.26 3.05-3.53 0-1.79-1.21-2.82-2.16-3.02z"></path>
            </svg>
        </div>
    </div>
</div>

<!-- Main Table -->
<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-12">
    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
        <h4 class="font-bold text-slate-800">Danh sách Đề xuất Thanh toán</h4>
        <div class="text-xs font-bold text-slate-400 bg-slate-200 px-3 py-1 rounded-full uppercase">Tháng <%= month %></div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-[11px] font-bold uppercase tracking-widest border-b border-slate-200">
                    <th class="px-6 py-4">Nhân viên & Vai trò</th>
                    <th class="px-6 py-4">Lương cứng</th>
                    <th class="px-6 py-4">Chỉ số Hiệu suất</th>
                    <th class="px-6 py-4">Hoa hồng (Dự kiến)</th>
                    <th class="px-6 py-4">Thực nhận dự kiến</th>
                    <th class="px-6 py-4">Trạng thái</th>
                    <th class="px-6 py-4 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(payrollData && payrollData.length > 0) { %>
                    <% payrollData.forEach(p => { %>
                        <tr class="hover:bg-slate-50/80 transition-colors group">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="size-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400 overflow-hidden shadow-inner">
                                        <% if(p.staff.avatar) { %>
                                            <img src="<%= p.staff.avatar %>" alt="Ảnh" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                            </svg>
                                        <% } %>
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-slate-800"><%= p.staff.name %></p>
                                        <p class="text-[10px] text-slate-400 uppercase tracking-wider">
                                            <% 
                                                let roleVN = p.staff.role;
                                                if(p.staff.role === 'PT') roleVN = 'Huấn luyện viên';
                                                if(p.staff.role === 'Sales') roleVN = 'Kinh doanh';
                                                if(p.staff.role === 'Accountant') roleVN = 'Kế toán';
                                                if(p.staff.role === 'Manager') roleVN = 'Quản lý';
                                            %>
                                            <%= roleVN %>
                                        </p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5 font-medium text-slate-600 text-sm">
                                <%= new Intl.NumberFormat('vi-VN').format(p.staff.baseSalary || 5000000) %> 
                            </td>
                            <td class="px-6 py-5">
                                <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-xs font-bold border border-slate-200">
                                    <%= p.detailCount %> <%= p.staff.role === 'PT' ? 'Buổi tập' : 'Hợp đồng' %>
                                </span>
                            </td>
                            <td class="px-6 py-5 text-sm font-bold <%= p.commission > 0 ? 'text-amber-600' : 'text-slate-400' %>">
                                +<%= new Intl.NumberFormat('vi-VN').format(p.commission) %>
                            </td>
                            <td class="px-6 py-5">
                                <p class="text-base font-black text-emerald-700"><%= new Intl.NumberFormat('vi-VN').format(p.totalEstimate) %></p>
                            </td>
                            <td class="px-6 py-5">
                                <% if(p.existingPayroll) { %>
                                    <span class="flex items-center gap-1.5 text-xs font-bold text-blue-600 bg-blue-50 px-2.5 py-1 rounded-lg border border-blue-100">
                                        <span class="size-1.5 rounded-full bg-blue-600 animate-pulse"></span>
                                        <% 
                                            let statusVN = p.existingPayroll.status;
                                            if(p.existingPayroll.status === 'Approved') statusVN = 'Đã phê duyệt';
                                            if(p.existingPayroll.status === 'Paid') statusVN = 'Đã thanh toán';
                                            if(p.existingPayroll.status === 'Draft') statusVN = 'Bản nháp';
                                        %>
                                        <%= statusVN %>
                                    </span>
                                <% } else { %>
                                    <span class="text-xs font-bold text-slate-400 border border-slate-200 px-2.5 py-1 rounded-lg">Bản nháp</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <form action="/admin/payroll/approve" method="POST">
                                    <input type="hidden" name="staffId" value="<%= p.staff._id %>">
                                    <input type="hidden" name="month" value="<%= month %>">
                                    <input type="hidden" name="year" value="<%= year %>">
                                    <input type="hidden" name="commission" value="<%= p.commission %>">
                                    <input type="hidden" name="totalSalary" value="<%= p.totalEstimate %>">
                                    
                                    <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-xl text-xs font-bold shadow-lg shadow-emerald-100 hover:bg-emerald-700 transition-all">
                                        Phê duyệt
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-400 italic bg-slate-50/20">
                            Không tìm thấy nhân viên nào trong kỳ tính lương này.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Extra Instructions / Policy and Info -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
    <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200">
        <h5 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Chính sách Hoa Hồng Mặc định
        </h5>
        <ul class="space-y-3 text-sm text-slate-600">
            <li class="flex items-start gap-2">
                <span class="size-1.5 rounded-full bg-indigo-500 mt-1.5 shrink-0"></span>
                <span><strong>Đối với PT:</strong> Hưởng 150,000đ cho mỗi buổi tập (Session) đã được Hội viên xác nhận hoàn thành công.</span>
            </li>
            <li class="flex items-start gap-2">
                <span class="size-1.5 rounded-full bg-indigo-500 mt-1.5 shrink-0"></span>
                <span><strong>Đối với Sales:</strong> Hưởng 5% doanh thu trên mỗi Hợp đồng (Contract) mới, ở trạng thái "Đã thanh toán".</span>
            </li>
            <li class="flex items-start gap-2">
                <span class="size-1.5 rounded-full bg-indigo-500 mt-1.5 shrink-0"></span>
                <span><strong>Lương cơ bản:</strong> Cố định 5,000,000đ dành cho tất cả nhân viên cộng tác toàn thời gian.</span>
            </li>
        </ul>
    </div>
    
    <div class="bg-rose-50 rounded-2xl p-6 border border-rose-100">
        <h5 class="font-bold text-rose-800 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            Lưu ý Quan trọng
        </h5>
        <p class="text-sm text-rose-700/80 leading-relaxed mb-4">
            Dữ liệu trên đây là <strong>Ước tính (Estimation)</strong> dựa trên hoạt động thực tế trong tháng. Khi bấm "Phê duyệt", hệ thống sẽ tạo bản ghi Payroll chính thức và chốt số liệu. 
        </p>
        <div class="bg-white/60 p-3 rounded-xl border border-rose-200 text-xs text-rose-800">
            Đảm bảo tất cả Session và Contract đã được đối soát trước khi chốt bảng lương.
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
