<%- include('../../partials/header', { title: 'Quản lý Nhân sự', activePage: 'users' }) %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Quản lý Tài Khoản & Nhân Sự</h2>
        <p class="text-slate-500 text-sm mt-1">Danh bạ, vai trò phân quyền và trạng thái công việc của nội bộ nhân viên</p>
    </div>
    <a href="/admin/users/create" class="inline-flex items-center justify-center px-4 py-2 bg-lime-500 hover:bg-lime-600 text-slate-900 font-semibold rounded-lg transition-colors shadow-sm">
        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
        </svg>
        Cấp phát Tài Khoản
    </a>
</div>

<!-- DATA TABLE -->
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <div class="w-full max-w-sm relative">
            <svg class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" placeholder="Tìm kiếm nhân viên..." class="pl-10 pr-4 py-2 w-full border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-lime-500 focus:border-lime-500 outline-none transition-all">
        </div>
        <div class="hidden sm:block text-sm text-slate-500">
            Tổng số: <span class="font-bold text-slate-800"><%= typeof users !== 'undefined' ? users.length : 0 %></span> nhân viên
        </div>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-sm uppercase tracking-wider border-b border-slate-200">
                    <th class="p-4 font-semibold">Tên / Liên hệ</th>
                    <th class="p-4 font-semibold text-center">Vai Trò (Role)</th>
                    <th class="p-4 font-semibold">Chi nhánh hiện tại</th>
                    <th class="p-4 font-semibold text-center">Trạng thái</th>
                    <th class="p-4 font-semibold text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(typeof users !== 'undefined' && users.length > 0) { %>
                    <% users.forEach(userData => { %>
                        <tr class="hover:bg-slate-50/70 transition-colors">
                            <td class="p-4">
                                <div class="flex items-center">
                                    <div class="h-10 w-10 flex-shrink-0">
                                        <img class="h-10 w-10 rounded-full border border-slate-200 object-cover" src="<%= userData.avatar || '/images/default-avatar.png' %>" alt=""
                                            onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(userData.name) %>&background=e2e8f0&color=475569'">
                                    </div>
                                    <div class="ml-4">
                                        <div class="font-bold text-slate-800"><%= userData.name %></div>
                                        <div class="text-xs text-slate-500"><%= userData.email %></div>
                                        <% if(userData.phone) { %>
                                        <div class="text-xs text-slate-400 mt-0.5"><%= userData.phone %></div>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4 text-center">
                                <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                    <%= userData.role === 'SA' || userData.role === 'Admin' ? 'bg-indigo-100 text-indigo-800' : 
                                       (userData.role === 'Manager' ? 'bg-fuchsia-100 text-fuchsia-800' : 
                                       (userData.role === 'PT' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-800')) %>">
                                    <%= userData.role %>
                                </span>
                            </td>
                            <td class="p-4 text-sm font-medium text-slate-700">
                                <% if(userData.role === 'SA' || userData.role === 'Admin') { %>
                                    <span class="text-indigo-600">Toàn hệ thống</span>
                                <% } else if(userData.branch) { %>
                                    <%= userData.branch.name %>
                                <% } else { %>
                                    <span class="text-red-500 italic">Chưa phân bổ</span>
                                <% } %>
                            </td>
                            <td class="p-4 text-center">
                                <% if(userData.status === 'Active') { %>
                                    <span class="inline-flex items-center"><span class="w-2 h-2 rounded-full bg-emerald-500 mr-1.5"></span><span class="text-sm text-emerald-700 font-medium">Hoạt động</span></span>
                                <% } else if(userData.status === 'Inactive') { %>
                                    <span class="inline-flex items-center"><span class="w-2 h-2 rounded-full bg-slate-400 mr-1.5"></span><span class="text-sm text-slate-600 font-medium">Nghỉ việc</span></span>
                                <% } else { %>
                                    <span class="inline-flex items-center"><span class="w-2 h-2 rounded-full bg-red-500 mr-1.5"></span><span class="text-sm text-red-700 font-medium">Bị Cấm</span></span>
                                <% } %>
                            </td>
                            <td class="p-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="/admin/users/edit/<%= userData._id %>" class="text-slate-400 hover:text-blue-600 transition-colors" title="Chỉnh sửa / Điều chuyển">
                                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                    </a>
                                    <!-- Tuỳ vào vai trò mà nút Delete có xuất hiện hay không, vì user hiện tại (Manager) không được quyền xoá -->
                                    <% if (user && (user.role === 'SA' || user.role === 'Admin')) { %>
                                        <form action="/admin/users/delete/<%= userData._id %>" method="POST" class="inline-block" onsubmit="return confirm('CẢNH BÁO CAO ĐỘ: Bạn có chắc chắn muốn xoá vĩnh viễn dữ liệu tài khoản này? Nếu họ đang có số buổi dạy (PT) sẽ bị lỗi liên kết dữ liệu. Nên ưu tiên chọn nút Sửa và đổi trạng thái về [Nghỉ việc] thay vì xoá cứng!');">
                                            <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors" title="Xóa tài khoản">
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="p-8 text-center text-slate-500">
                            Chưa có dữ liệu nhân sự!
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../partials/footer') %>
