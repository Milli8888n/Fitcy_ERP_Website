<!DOCTYPE html>

<html class="dark" lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#ccff00",
                        "background-light": "#f8f8f5",
                        "background-dark": "#121212",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
<style>
        body { font-family: 'Inter', sans-serif; }
        .progress-ring { transform: rotate(-90deg); }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen pb-24">
<%- include('../partials/flash') %>
<!-- Header -->
<header class="flex items-center justify-between px-6 py-4 sticky top-0 z-50 bg-background-dark/80 backdrop-blur-md">
<h1 class="text-primary text-2xl font-black tracking-tighter">FITCITY</h1>
<div class="flex items-center gap-4">
<button class="relative p-2 text-slate-400 hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[28px]">notifications</span>
<span class="absolute top-2 right-2 flex h-2 w-2 rounded-full bg-primary"></span>
</button>
<div class="h-10 w-10 rounded-full border-2 border-primary/30 overflow-hidden">
<img alt="User Profile" class="h-full w-full object-cover" data-alt="<%= user && user.name ? user.name : 'Client' %>" src="<%= user && user.avatar ? user.avatar : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user && user.name ? user.name : 'C') + '&background=ccff00&color=121212' %>"/>
</div>
</div>
</header>
<main class="px-6 space-y-6">
<!-- Hero Area: Progress Arc -->
<section class="bg-slate-900/50 dark:bg-primary/5 rounded-2xl p-8 border border-primary/10 flex flex-col items-center text-center">
<div class="relative flex items-center justify-center mb-4">
<!-- SVG Semi-circle Progress -->
<svg class="w-48 h-28" viewbox="0 0 100 60">
<path class="text-slate-800" d="M 10 50 A 40 40 0 1 1 90 50" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="8"></path>
<path class="text-primary" d="M 10 50 A 40 40 0 0 1 50 10" fill="none" stroke="currentColor" stroke-dasharray="126" stroke-dashoffset="<%= typeof sessionsCompleted !== 'undefined' && typeof totalSessions !== 'undefined' && totalSessions > 0 ? (126 - (126 * (sessionsCompleted / totalSessions))) : 126 %>" stroke-linecap="round" stroke-width="8"></path>
</svg>
<div class="absolute inset-0 flex flex-col items-center justify-end pb-2">
<span class="text-3xl font-extrabold text-white"><%= typeof sessionsCompleted !== 'undefined' ? sessionsCompleted : 0 %>/<%= typeof totalSessions !== 'undefined' ? totalSessions : 0 %></span>
<span class="text-xs uppercase tracking-widest text-primary font-semibold">Đã hoàn thành</span>
</div>
</div>
<h3 class="text-slate-100 text-lg font-bold"><%= typeof packageName !== 'undefined' ? packageName : 'Chưa đăng ký Gói' %></h3>
<p class="text-slate-400 text-sm mt-1">
    <%= typeof sessionsCompleted !== 'undefined' && typeof totalSessions !== 'undefined' && sessionsCompleted >= totalSessions ? 'Bạn đã hoàn tất lộ trình gói tập!' : 'Giữ vững phong độ nhé!' %>
</p>
</section>
<% if (typeof pendingConfirmation !== 'undefined' && pendingConfirmation) { %>
<!-- Action Area: Alert Card -->
<section class="bg-slate-800 rounded-2xl p-6 border-l-4 border-primary shadow-2xl animate-pulse">
<div class="flex items-start gap-4 mb-4">
<div class="h-12 w-12 rounded-full overflow-hidden shrink-0 border border-slate-700 shadow-inner">
<img alt="Coach" class="h-full w-full object-cover" src="<%= pendingConfirmation.pt.avatar || 'https://ui-avatars.com/api/?name=Coach&background=333&color=fff' %>"/>
</div>
<div class="flex-1">
<h4 class="text-primary font-bold text-xs uppercase tracking-widest">Chờ xác nhận tập luyện</h4>
<p class="text-slate-200 text-sm mt-1 leading-relaxed">HLV <strong><%= pendingConfirmation.pt.name %></strong> vừa hoàn thành buổi tập cùng bạn lúc <%= new Date(pendingConfirmation.endTime).toLocaleTimeString('vi-VN') %>. Xác nhận ngay để tích luỹ số buổi!</p>
</div>
</div>
<form action="/client/sessions/confirm/<%= pendingConfirmation._id %>" method="POST">
    <button type="submit" class="w-full bg-primary hover:bg-white text-background-dark font-black py-3.5 rounded-xl text-center transition-all active:scale-[0.98] uppercase tracking-tighter shadow-lg shadow-primary/20">
        XÁC NHẬN ĐÃ TẬP XONG
    </button>
</form>
</section>
<% } %>
<!-- Nutrition Summary Area -->
<% if (typeof mealPlan !== 'undefined' && mealPlan) { %>
<section class="bg-dark-card border border-white/5 rounded-2xl p-6 shadow-2xl">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-xl font-bold text-white tracking-tight">Phác đồ dinh dưỡng</h2>
            <p class="text-[10px] text-primary font-black uppercase tracking-widest mt-1"><%= mealPlan.goal %></p>
        </div>
        <div class="text-right">
            <span class="text-3xl font-black text-primary leading-none"><%= mealPlan.dailyCalories %></span>
            <p class="text-[9px] text-slate-500 font-bold uppercase tracking-tighter">Ngân sách Kcal</p>
        </div>
    </div>

    <!-- Macro Breakdown -->
    <div class="grid grid-cols-3 gap-3">
        <div class="bg-background-dark/50 p-4 rounded-2xl border border-white/5 text-center transition-all hover:border-primary/20 cursor-default">
            <p class="text-[9px] text-slate-500 font-bold uppercase mb-1">Đạm</p>
            <div class="flex items-end justify-center gap-0.5">
                <span class="text-xl font-black text-white"><%= mealPlan.macros.protein %></span>
                <span class="text-[10px] text-slate-600 mb-1">%</span>
            </div>
        </div>
        <div class="bg-background-dark/50 p-4 rounded-2xl border border-white/5 text-center transition-all hover:border-primary/20 cursor-default">
            <p class="text-[9px] text-slate-500 font-bold uppercase mb-1">Tinh bột</p>
            <div class="flex items-end justify-center gap-0.5">
                <span class="text-xl font-black text-white"><%= mealPlan.macros.carbs %></span>
                <span class="text-[10px] text-slate-600 mb-1">%</span>
            </div>
        </div>
        <div class="bg-background-dark/50 p-4 rounded-2xl border border-white/5 text-center transition-all hover:border-primary/20 cursor-default">
            <p class="text-[9px] text-slate-500 font-bold uppercase mb-1">Chất béo</p>
            <div class="flex items-end justify-center gap-0.5">
                <span class="text-xl font-black text-white"><%= mealPlan.macros.fat %></span>
                <span class="text-[10px] text-slate-600 mb-1">%</span>
            </div>
        </div>
    </div>
    
    <!-- Next Meal Hint -->
    <div class="mt-6 flex items-center justify-between px-2">
        <div class="flex items-center gap-3">
            <div class="size-2 rounded-full bg-primary animate-pulse shadow-glow shadow-primary/40"></div>
            <span class="text-xs font-bold text-slate-200">Xem lịch chi tiết</span>
        </div>
        <a href="/client/nutrition" class="text-primary hover:translate-x-1 transition-transform">
            <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </a>
    </div>
</section>
<% } %>

<!-- Today's Plan -->
<section class="space-y-4">
<div class="flex justify-between items-end">
<h2 class="text-xl font-bold text-white">Bài tập hàng ngày</h2>
<a class="text-primary text-xs font-bold uppercase tracking-wider hover:underline" href="/client/workouts">Thư viện bài tập</a>
</div>
<div class="relative h-48 rounded-2xl overflow-hidden group cursor-pointer border border-slate-800">
<div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/40 to-transparent z-10"></div>
<img alt="Leg Day" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" data-alt="Fitness athlete performing squats in a modern gym" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZI_1hRkgF7Gq-ixAdfzz7_2faBRIsBRD9eenfhMX_o0KLG_dladscgKEsI4gB2dgXoLX6IlkSmF36AZkv-DN0GQoXtz-or7DPBu33rJULcJJflqp66YQwr879i3GLp-ESPvoKjmXMR-8C4Oi_u0pfZLU40ND-GHcZAPW7bh-KIuz0dfOXj7s0DVWQ1uRE06nbKyHevoE5IGjnuJJ3PssUyW9qE4bafkl4Pgb6-2d3y4TObIY20il-DfVH9_FMVWRGc-cfU_ZuPu4"/>
<div class="absolute bottom-0 left-0 p-5 z-20 w-full">
<div class="flex justify-between items-center">
<div>
<span class="inline-block px-2 py-1 bg-primary text-background-dark text-[10px] font-black rounded uppercase mb-2">60 Min</span>
<h3 class="text-xl font-black text-white leading-tight">Ngày chân - Tập trung sức mạnh</h3>
</div>
<div class="h-10 w-10 rounded-full bg-white/10 backdrop-blur flex items-center justify-center text-white">
<span class="material-symbols-outlined">play_arrow</span>
</div>
</div>
</div>
</div>
</section>
</main>
<!-- Bottom Navigation: Rounded Floating Pill -->
<nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[95%] max-w-lg z-50">
<div class="bg-slate-900/90 backdrop-blur-xl border border-white/5 rounded-full px-4 py-3 grid grid-cols-5 items-center shadow-2xl">
<a class="flex flex-col items-center gap-1 text-primary" href="/client">
<span class="material-symbols-outlined text-[24px] fill-[1]">home</span>
<span class="text-[8px] font-black uppercase tracking-tighter leading-none">Home</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/workouts">
<span class="material-symbols-outlined text-[24px]">fitness_center</span>
<span class="text-[8px] font-black uppercase tracking-tighter leading-none">Train</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/nutrition">
<span class="material-symbols-outlined text-[24px]">restaurant</span>
<span class="text-[8px] font-black uppercase tracking-tighter leading-none">Food</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/progress">
<span class="material-symbols-outlined text-[24px]">monitoring</span>
<span class="text-[8px] font-black uppercase tracking-tighter leading-none">Stats</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-500 hover:text-red-500 transition-all border-l border-white/5 pl-2" href="/auth/logout" onclick="return confirm('Bạn muốn thoát?');">
<span class="material-symbols-outlined text-[24px]">logout</span>
<span class="text-[8px] font-black uppercase tracking-tighter leading-none">Exit</span>
</a>
</div>
</nav>
</body></html>