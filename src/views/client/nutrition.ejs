<!DOCTYPE html>
<html class="dark" lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>FITCITY - Protocol Dinh dưỡng</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#ccff00",
                        "background-dark": "#0a0a0a",
                        "dark-card": "#151515"
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background: #0a0a0a; color: #fff; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="min-h-screen pb-32">
    <!-- Header -->
    <header class="sticky top-0 z-50 flex items-center bg-background-dark/80 backdrop-blur-xl p-6 justify-between border-b border-white/5">
        <div class="flex items-center gap-4">
            <a href="/client" class="size-11 flex items-center justify-center rounded-2xl bg-white/5 text-white hover:bg-white/10 transition-all active:scale-95 border border-white/5">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="text-xl font-black tracking-tight">Kế hoạch dinh dưỡng</h2>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Phác đồ cá nhân hóa</p>
            </div>
        </div>
        <div class="size-11 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined">restaurant</span>
        </div>
    </header>

    <main class="p-6 space-y-8 max-w-lg mx-auto">
        <% if (typeof mealPlan !== 'undefined' && mealPlan) { %>
            <!-- Macro Summary Card -->
            <div class="bg-dark-card rounded-[2.5rem] p-8 border border-white/5 shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 right-0 p-6 opacity-10">
                    <span class="material-symbols-outlined text-[120px]">nutrition</span>
                </div>
                
                <div class="relative z-10 flex flex-col items-center">
                    <div class="text-[10px] font-black text-primary uppercase tracking-[0.3em] mb-2 bg-primary/5 px-4 py-1.5 rounded-full border border-primary/10"><%= mealPlan.goal %></div>
                    <div class="flex items-baseline gap-2">
                        <span class="text-6xl font-black tracking-tighter"><%= mealPlan.dailyCalories %></span>
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Kcal</span>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-3 mt-10">
                    <div class="bg-background-dark/50 p-5 rounded-3xl border border-white/5 text-center">
                        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest mb-2">Đạm</p>
                        <div class="text-2xl font-black text-white"><%= mealPlan.macros.protein %>%</div>
                    </div>
                    <div class="bg-background-dark/50 p-5 rounded-3xl border border-white/5 text-center">
                        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest mb-2">Tinh bột</p>
                        <div class="text-2xl font-black text-white"><%= mealPlan.macros.carbs %>%</div>
                    </div>
                    <div class="bg-background-dark/50 p-5 rounded-3xl border border-white/5 text-center">
                        <p class="text-[10px] text-slate-500 font-black uppercase tracking-widest mb-2">Chất béo</p>
                        <div class="text-2xl font-black text-white"><%= mealPlan.macros.fat %>%</div>
                    </div>
                </div>
            </div>

            <!-- Schedule List -->
            <section class="space-y-4">
                <div class="flex justify-between items-center px-2">
                    <h3 class="text-sm font-black uppercase tracking-widest text-slate-500">Lịch ăn hàng ngày</h3>
                    <div class="text-[10px] font-bold text-primary italic">Cập nhật mỗi tháng</div>
                </div>
                
                <div class="space-y-4">
                    <% mealPlan.meals.forEach((meal, index) => { %>
                        <div class="bg-dark-card border border-white/5 p-6 rounded-[2rem] hover:border-white/20 transition-all group">
                            <div class="flex justify-between items-start mb-4">
                                <div class="flex items-center gap-4">
                                    <div class="size-12 rounded-2xl bg-white/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                                        <span class="material-symbols-outlined">schedule</span>
                                    </div>
                                    <div>
                                        <h4 class="font-black text-white text-lg"><%= meal.time %></h4>
                                        <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wider"><%= index === 0 ? 'Bữa sáng sớm' : (index === mealPlan.meals.length - 1 ? 'Bữa trước khi ngủ' : 'Bữa chính') %></p>
                                    </div>
                                </div>
                                <% if (meal.foodItems && meal.foodItems.length > 0) { %>
                                    <% let mealCals = meal.foodItems.reduce((acc, curr) => acc + (curr.calories || 0), 0); %>
                                    <div class="text-right">
                                        <div class="text-lg font-black text-white"><%= mealCals %></div>
                                        <div class="text-[9px] text-slate-600 font-bold uppercase">Kcal</div>
                                    </div>
                                <% } %>
                            </div>

                            <div class="space-y-3 bg-white/[0.02] p-4 rounded-2xl border border-white/5">
                                <% meal.foodItems.forEach(item => { %>
                                    <div class="flex justify-between items-center text-sm">
                                        <div class="flex items-center gap-2">
                                            <div class="size-1.5 rounded-full bg-primary/40"></div>
                                            <span class="text-slate-200 font-medium"><%= item.name %></span>
                                        </div>
                                        <span class="text-slate-500 font-mono text-xs"><%= item.quantity %></span>
                                    </div>
                                <% }) %>
                            </div>

                            <% if (meal.notes) { %>
                                <div class="mt-4 flex gap-3 items-start text-xs text-slate-400 bg-emerald-500/5 p-3 rounded-xl border border-emerald-500/10">
                                    <span class="material-symbols-outlined text-[16px] text-emerald-500">info</span>
                                    <p class="italic"><%= meal.notes %></p>
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </section>

            <!-- PT Note -->
            <% if (mealPlan.pt) { %>
                <div class="bg-primary p-8 rounded-[3rem] text-background-dark shadow-2xl shadow-primary/20 flex flex-col items-center text-center gap-4">
                    <div class="size-20 rounded-full border-4 border-background-dark/20 overflow-hidden">
                        <img src="<%= mealPlan.pt.avatar %>" alt="PT" class="w-full h-full object-cover">
                    </div>
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-60">Huấn luyện viên</p>
                        <h4 class="text-xl font-black tracking-tighter">Xác nhận bởi <%= mealPlan.pt.name %></h4>
                    </div>
                    <p class="text-sm font-bold leading-relaxed opacity-80">"Kiên trì là chìa khóa để thấy kết quả rõ rệt. Hãy tuân thủ lịch ăn và uống đủ nước!"</p>
                </div>
            <% } %>

        <% } else { %>
            <!-- Empty State -->
            <div class="flex flex-col items-center justify-center py-40 text-center">
                <div class="size-24 rounded-full bg-white/5 flex items-center justify-center text-slate-600 mb-6 border border-white/10">
                    <span class="material-symbols-outlined text-[40px]">flatware</span>
                </div>
                <h3 class="text-2xl font-black text-white tracking-tighter mb-2">Chưa có thực đơn</h3>
                <p class="text-slate-500 text-sm max-w-[240px]">Huấn luyện viên của bạn đang xây dựng lộ trình dinh dưỡng. Vui lòng quay lại sau.</p>
            </div>
        <% } %>
    </main>

    <!-- Bottom Nav -->
    <nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[95%] max-w-lg z-50">
        <div class="bg-slate-900/90 backdrop-blur-xl border border-white/5 rounded-full px-4 py-3 grid grid-cols-5 items-center shadow-2xl">
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client">
                <span class="material-symbols-outlined text-[24px]">home</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Home</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/workouts">
                <span class="material-symbols-outlined text-[24px]">fitness_center</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Train</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-primary" href="/client/nutrition">
                <span class="material-symbols-outlined text-[24px] fill-[1]">restaurant</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Food</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/progress">
                <span class="material-symbols-outlined text-[24px]">monitoring</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Stats</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-red-500 transition-all border-l border-white/5 pl-2" href="/auth/logout" onclick="return confirm('Bạn muốn thoát?');">
                <span class="material-symbols-outlined text-[24px]">logout</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Exit</span>
            </a>
        </div>
    </nav>
</body>
</html>