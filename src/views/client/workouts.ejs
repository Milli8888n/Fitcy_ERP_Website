
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch tập & Thư viện - FitCity</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0d0d0d; color: #ffffff; }
        .text-primary { color: #ccff00; }
        .bg-primary { background-color: #ccff00; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="p-6 md:p-12 mb-32 overflow-x-hidden">
    <header class="flex justify-between items-start mb-12">
        <div>
            <h1 class="text-4xl font-black italic tracking-tighter uppercase leading-none"><span class="text-primary tracking-normal">BÀI TẬP</span> & LỊCH</h1>
            <p class="text-slate-500 text-sm mt-2">Theo dõi lộ trình rèn luyện cùng PT của bạn.</p>
        </div>
        <a href="/client" class="w-12 h-12 glass rounded-full flex items-center justify-center hover:bg-white/10 transition-all">
            <span class="material-symbols-outlined">close</span>
        </a>
    </header>

    <main class="space-y-12">
        <!-- Next/Recent Session -->
        <section>
            <h2 class="text-xs font-black uppercase tracking-[0.2em] text-slate-500 mb-6 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary"></span> Buổi tập gần đây nhất
            </h2>
            
            <% if (sessions && sessions.length > 0) { %>
                <div class="glass p-8 rounded-[40px] relative overflow-hidden group">
                    <div class="absolute -right-12 -top-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-700"></div>
                    
                    <div class="flex flex-col md:flex-row gap-8 items-center relative z-10">
                        <div class="h-24 w-24 rounded-3xl overflow-hidden shadow-2xl border-2 border-primary/20 shrink-0">
                            <img src="<%= sessions[0].pt.avatar || 'https://ui-avatars.com/api/?name=Coach&background=333&color=fff' %>" class="w-full h-full object-cover">
                        </div>
                        <div class="flex-1 text-center md:text-left">
                            <h3 class="text-2xl font-black text-white mb-2"><%= sessions[0].workoutPlan || 'Ngày chân & Sức bền' %></h3>
                            <div class="flex flex-wrap items-center justify-center md:justify-start gap-4">
                                <span class="flex items-center gap-1.5 text-slate-400 text-xs font-bold uppercase tracking-widest">
                                    <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                                    <%= new Date(sessions[0].scheduledTime).toLocaleDateString('vi-VN') %>
                                </span>
                                <span class="flex items-center gap-1.5 text-slate-400 text-xs font-bold uppercase tracking-widest">
                                    <span class="material-symbols-outlined text-[18px]">person</span>
                                    Coach <%= sessions[0].pt.name %>
                                </span>
                                <span class="px-3 py-1 <%= sessions[0].status === 'Completed' ? 'bg-primary/20 text-primary' : 'bg-orange-500/20 text-orange-500' %> text-[10px] font-black rounded-full uppercase">
                                    <%= sessions[0].status %>
                                </span>
                            </div>
                        </div>
                        <div class="w-full md:w-auto">
                            <button class="w-full md:w-auto px-10 py-4 bg-primary text-black font-black italic uppercase rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20">
                                CHI TIẾT BÀI TẬP
                            </button>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="glass p-12 rounded-[40px] text-center">
                    <p class="text-slate-500 font-bold uppercase tracking-widest">Bạn chưa có lịch tập nào được lên!</p>
                </div>
            <% } %>
        </section>

        <!-- Exercises Library (Mock/Static for premium look) -->
        <section>
            <div class="flex justify-between items-end mb-8">
                <h2 class="text-xl font-black italic uppercase tracking-tighter">THƯ VIỆN BÀI TẬP</h2>
                <div class="flex gap-2">
                    <button class="w-10 h-10 glass border border-white/5 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary transition-all">
                        <span class="material-symbols-outlined">filter_list</span>
                    </button>
                    <button class="w-10 h-10 glass border border-white/5 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary transition-all">
                        <span class="material-symbols-outlined">search</span>
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                <!-- Exercise 1 -->
                <div class="group cursor-pointer">
                    <div class="relative aspect-square rounded-[32px] overflow-hidden mb-4 border border-white/5">
                        <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1470" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center translate-y-4 group-hover:translate-y-0 transition-transform opacity-0 group-hover:opacity-100">
                            <span class="text-[10px] font-black bg-primary text-black px-2 py-1 rounded uppercase">Compound</span>
                            <span class="material-symbols-outlined text-white text-[20px]">play_circle</span>
                        </div>
                    </div>
                    <h4 class="text-sm font-black text-white tracking-tight px-1">Barbell Squat</h4>
                    <p class="text-[10px] text-slate-500 font-bold uppercase mt-1 px-1">Quadriceps, Glutes</p>
                </div>

                <!-- Exercise 2 -->
                <div class="group cursor-pointer">
                    <div class="relative aspect-square rounded-[32px] overflow-hidden mb-4 border border-white/5">
                        <img src="https://images.unsplash.com/photo-1541534741688-6078c64b5903?q=80&w=1470" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center translate-y-4 group-hover:translate-y-0 transition-transform opacity-0 group-hover:opacity-100">
                            <span class="text-[10px] font-black bg-primary text-black px-2 py-1 rounded uppercase">Strength</span>
                            <span class="material-symbols-outlined text-white text-[20px]">play_circle</span>
                        </div>
                    </div>
                    <h4 class="text-sm font-black text-white tracking-tight px-1">Bench Press</h4>
                    <p class="text-[10px] text-slate-500 font-bold uppercase mt-1 px-1">Chest, Triceps</p>
                </div>

                <!-- Exercise 3 -->
                <div class="group cursor-pointer">
                    <div class="relative aspect-square rounded-[32px] overflow-hidden mb-4 border border-white/5">
                        <img src="https://images.unsplash.com/photo-1599058917232-d750c18590e6?q=80&w=1470" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center translate-y-4 group-hover:translate-y-0 transition-transform opacity-0 group-hover:opacity-100">
                            <span class="text-[10px] font-black bg-primary text-black px-2 py-1 rounded uppercase">Back</span>
                            <span class="material-symbols-outlined text-white text-[20px]">play_circle</span>
                        </div>
                    </div>
                    <h4 class="text-sm font-black text-white tracking-tight px-1">Lat Pulldown</h4>
                    <p class="text-[10px] text-slate-500 font-bold uppercase mt-1 px-1">Back, Lats</p>
                </div>

                <!-- Exercise 4 -->
                <div class="group cursor-pointer">
                    <div class="relative aspect-square rounded-[32px] overflow-hidden mb-4 border border-white/5">
                        <img src="https://images.unsplash.com/photo-1594737625785-affcbdbcd000?q=80&w=1470" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center translate-y-4 group-hover:translate-y-0 transition-transform opacity-0 group-hover:opacity-100">
                            <span class="text-[10px] font-black bg-primary text-black px-2 py-1 rounded uppercase">Cardio</span>
                            <span class="material-symbols-outlined text-white text-[20px]">play_circle</span>
                        </div>
                    </div>
                    <h4 class="text-sm font-black text-white tracking-tight px-1">Jump Rope</h4>
                    <p class="text-[10px] text-slate-500 font-bold uppercase mt-1 px-1">Endurance, Heart</p>
                </div>
            </div>
        </section>
    </main>

    <!-- Navigation Bar -->
    <nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[95%] max-w-lg z-50">
        <div class="bg-slate-900/90 backdrop-blur-xl border border-white/5 rounded-full px-4 py-3 grid grid-cols-5 items-center shadow-2xl">
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client">
                <span class="material-symbols-outlined text-[24px]">home</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Home</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-primary" href="/client/workouts">
                <span class="material-symbols-outlined text-[24px] fill-[1]">fitness_center</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Train</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/nutrition">
                <span class="material-symbols-outlined text-[24px]">restaurant</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Food</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-primary transition-all" href="/client/progress">
                <span class="material-symbols-outlined text-[24px]">monitoring</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Stats</span>
            </a>
            <a class="flex flex-col items-center gap-1 text-slate-500 hover:text-red-500 transition-all border-l border-white/5 pl-2" href="/auth/logout" onclick="return confirm('Bạn muốn thoát?');">
                <span class="material-symbols-outlined text-[24px]">logout</span>
                <span class="text-[8px] font-black uppercase tracking-tighter leading-none">Exit</span>
            </a>
        </div>
    </nav>
</body>
</html>
