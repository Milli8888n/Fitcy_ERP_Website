<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitCity - Nâng Tầm Thể Chất, Khẳng Định Bản Thân</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; color: #ffffff; }
        .text-primary { color: #ccff00; }
        .bg-primary { background-color: #ccff00; }
        .border-primary { border-color: #ccff00; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .neon-glow { box-shadow: 0 0 20px rgba(204, 255, 0, 0.2); }
        .hero-gradient { background: radial-gradient(circle at 70% 30%, rgba(204, 255, 0, 0.15) 0%, transparent 60%); }
    </style>
</head>
<body class="overflow-x-hidden">
    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 glass px-6 py-4 flex justify-between items-center">
        <div class="text-2xl font-black tracking-tighter text-primary">FITCITY</div>
        <div class="hidden md:flex gap-8 text-sm font-semibold text-slate-400">
            <a href="#about" class="hover:text-primary transition-colors">Về chúng tôi</a>
            <a href="#packages" class="hover:text-primary transition-colors">Gói tập</a>
            <a href="#branches" class="hover:text-primary transition-colors">Chi nhánh</a>
        </div>
        <div class="flex items-center gap-4">
            <a href="/auth/login" class="text-sm font-bold text-slate-300 hover:text-white">Đăng nhập</a>
            <a href="#trial" class="px-5 py-2 bg-primary text-black text-sm font-black rounded-lg uppercase tracking-tight hover:brightness-110 transition-all">Tập thử 0đ</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center pt-20 hero-gradient">
        <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="z-10">
                <span class="inline-block px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-6 text-primary">
                    Trải nghiệm Thể hình Đỉnh cao
                </span>
                <h1 class="text-6xl md:text-8xl font-black leading-[0.9] mb-8 tracking-tighter">
                    THÁCH THỨC <br> <span class="text-primary">GIỚI HẠN.</span>
                </h1>
                <p class="text-slate-400 text-lg mb-10 max-w-lg leading-relaxed">
                    Hệ thống phòng tập 5 sao với thiết bị nhập khẩu 100%, đội ngũ PT chuyên nghiệp và lộ trình dinh dưỡng cá nhân hóa dựa trên AI.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#trial" class="px-8 py-4 bg-primary text-black font-black rounded-xl text-center shadow-xl shadow-primary/20 hover:scale-105 transition-all uppercase tracking-tight">Bắt đầu ngay hôm nay</a>
                    <div class="flex items-center gap-3 px-6 py-4 border border-white/10 rounded-xl glass">
                        <div class="flex -space-x-3">
                            <div class="w-8 h-8 rounded-full border-2 border-slate-900 bg-slate-700"></div>
                            <div class="w-8 h-8 rounded-full border-2 border-slate-900 bg-slate-600"></div>
                            <div class="w-8 h-8 rounded-full border-2 border-slate-900 bg-slate-500"></div>
                        </div>
                        <span class="text-xs font-bold text-slate-400">2,500+ Hội viên hài lòng</span>
                    </div>
                </div>
            </div>
            
            <!-- Lead Form -->
            <div id="trial" class="glass p-8 md:p-10 rounded-3xl relative overflow-hidden group shadow-2xl">
                <div class="absolute -right-20 -top-20 w-40 h-40 bg-primary/20 rounded-full blur-3xl group-hover:bg-primary/30 transition-all"></div>
                
                <h2 class="text-2xl font-black mb-2 italic">NHẬN 07 NGÀY TẬP THỬ <span class="text-primary">MIỄN PHÍ</span></h2>
                <p class="text-slate-400 text-sm mb-8 font-medium">Để lại thông tin, FitCity sẽ liên hệ tư vấn trong 2h làm việc.</p>

                <% if (success_msg.length > 0) { %>
                    <div class="mb-6 p-4 bg-primary/10 border border-primary/20 rounded-xl text-primary text-sm font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        <%= success_msg %>
                    </div>
                <% } %>

                <form action="/register-lead" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Họ và tên</label>
                        <input type="text" name="name" required placeholder="Nguyễn Văn A" 
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all placeholder:text-slate-700">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Số điện thoại</label>
                            <input type="tel" name="phone" required placeholder="090..." 
                                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Email (nếu có)</label>
                            <input type="email" name="email" placeholder="email@gmail.com" 
                                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all placeholder:text-slate-700">
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Chi nhánh quan tâm</label>
                        <select name="branchId" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white appearance-none focus:outline-none focus:border-primary/50 transition-all">
                            <% if (typeof branches !== 'undefined' && branches.length > 0) { %>
                                <% branches.forEach(branch => { %>
                                    <option value="<%= branch._id %>" class="bg-slate-900"><%= branch.name %></option>
                                <% }) %>
                            <% } else { %>
                                <option disabled class="bg-slate-900 italic">Dữ liệu chi nhánh đang cập nhật...</option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Gói tập mục tiêu</label>
                        <div class="flex flex-wrap gap-2 mt-2">
                            <label class="cursor-pointer">
                                <input type="radio" name="interestedPackage" value="Gym" checked class="hidden peer">
                                <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-bold peer-checked:bg-primary peer-checked:text-black transition-all">GYM</span>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="interestedPackage" value="Yoga" class="hidden peer">
                                <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-bold peer-checked:bg-primary peer-checked:text-black transition-all">YOGA</span>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="interestedPackage" value="PT" class="hidden peer">
                                <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-bold peer-checked:bg-primary peer-checked:text-black transition-all">PT 1:1</span>
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="w-full py-5 bg-primary text-black font-black rounded-xl uppercase tracking-tighter shadow-xl shadow-primary/10 hover:brightness-110 active:scale-95 transition-all mt-4">
                        Gửi yêu cầu đăng ký
                    </button>
                    <p class="text-[10px] text-slate-500 text-center mt-4">Bằng cách bấm đăng ký, bạn đồng ý với các <a href="#" class="underline">Điều khoản dịch vụ</a> của FitCity.</p>
                </form>
            </div>
        </div>
    </section>

    <!-- Branding Footer (Mini) -->
    <footer class="py-12 border-t border-white/5">
        <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="text-xl font-black text-primary opacity-50">FITCITY</div>
            <div class="flex gap-12 text-xs font-bold text-slate-600 uppercase tracking-widest">
                <span>Facebook</span>
                <span>Instagram</span>
                <span>TikTok</span>
            </div>
            <div class="text-[10px] text-slate-700 italic">© 2026 FitCity. Toàn quyền bảo lưu.</div>
        </div>
    </footer>
</body>
</html>
