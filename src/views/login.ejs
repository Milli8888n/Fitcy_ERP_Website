<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>FitCity - Đăng nhập</title>
  <!-- Tailwind CSS CDN with plugins -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <!-- BEGIN: Tailwind Configuration -->
  <script data-purpose="tailwind-config">
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              black: '#121212',
              neon: '#ccff00',
              gray: '#1e1e1e'
            }
          }
        }
      }
    }
  </script>
  <!-- END: Tailwind Configuration -->
  <style data-purpose="custom-transitions">
    /* Custom focus ring for the neon theme */
    .neon-focus:focus-within {
      box-shadow: 0 0 10px rgba(204, 255, 0, 0.3);
    }
    
    /* Subtle glow for the login button */
    .btn-glow:active {
      box-shadow: 0 0 15px rgba(204, 255, 0, 0.5);
      transform: scale(0.98);
    }
  </style>
</head>
<body class="bg-brand-black text-white min-h-screen flex flex-col font-sans">
  <header class="pt-16 pb-8 text-center" data-purpose="app-branding">
    <h1 class="text-3xl font-extrabold tracking-tighter italic">
      FITCITY
    </h1>
    <p class="text-gray-500 text-sm mt-2 uppercase tracking-widest">Hệ thống quản lý phòng tập</p>
  </header>

  <main class="flex-grow px-6 flex items-center justify-center">
    <div class="w-full max-w-sm p-8 rounded-2xl bg-brand-gray border border-brand-neon/20 shadow-2xl" data-purpose="login-card">
      <div class="mb-8">
        <h2 class="text-xl font-bold">Chào mừng trở lại</h2>
        <p class="text-gray-400 text-sm">Vui lòng nhập thông tin để tiếp tục.</p>
      </div>
      
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="bg-red-500/10 border border-red-500 text-red-500 text-sm px-4 py-2 rounded-lg mb-4 text-center">
            <%= error_msg %>
        </div>
      <% } %>

      <form action="/auth/login" class="space-y-6" method="POST">
        <!-- Email Field -->
        <div class="space-y-2">
          <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider" for="email">Địa chỉ Email</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-500 group-focus-within:text-brand-neon transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
              </svg>
            </div>
            <input class="block w-full pl-10 bg-brand-black border-transparent rounded-lg text-white placeholder-gray-600 focus:border-brand-neon focus:ring-1 focus:ring-brand-neon transition-all" id="email" name="email" placeholder="email@congty.com" required="" type="email"/>
          </div>
        </div>

        <!-- Password Field -->
        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider" for="password">Mật khẩu</label>
          </div>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-500 group-focus-within:text-brand-neon transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
              </svg>
            </div>
            <input class="block w-full pl-10 bg-brand-black border-transparent rounded-lg text-white placeholder-gray-600 focus:border-brand-neon focus:ring-1 focus:ring-brand-neon transition-all" id="password" name="password" placeholder="••••••••" required="" type="password"/>
          </div>
        </div>

        <!-- Submit Button -->
        <button class="w-full py-4 bg-brand-neon text-brand-black font-black uppercase tracking-widest rounded-lg hover:bg-opacity-90 transition-all btn-glow" data-purpose="submit-login" type="submit">
          Đăng nhập
        </button>
      </form>
    </div>
  </main>
</body>
</html>
