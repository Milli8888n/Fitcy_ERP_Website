<% if (success_msg && success_msg.length > 0) { %>
    <div class="mb-4 p-4 bg-green-100 border border-green-200 text-green-700 rounded-lg flex justify-between items-center">
        <span><%= success_msg %></span>
        <button onclick="this.parentElement.remove()" class="text-green-500 hover:text-green-700 font-bold">&times;</button>
    </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
    <div class="mb-4 p-4 bg-red-100 border border-red-200 text-red-700 rounded-lg flex justify-between items-center">
        <span><%= error_msg %></span>
        <button onclick="this.parentElement.remove()" class="text-red-500 hover:text-red-700 font-bold">&times;</button>
    </div>
<% } %>
