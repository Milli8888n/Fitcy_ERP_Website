<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>FitCity - <%= typeof title !=='undefined' ? title : 'Hệ thống quản lý' %></title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .sidebar-active {
            background-color: rgba(163, 230, 53, 0.1); /* Lime-400 hint */
            border-left: 4px solid #a3e635;
            color: #4d7c0f; /* Lime-700 */
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-800">
    <div class="flex min-h-screen">
        <!-- BEGIN: Sidebar -->
        <aside class="w-64 bg-slate-900 border-r border-slate-800 flex-shrink-0 hidden md:flex flex-col text-slate-300">
            <div class="p-6 border-b border-slate-800">
                <h1 class="text-xl font-bold flex items-center gap-2" style="color: #ccff00;">
                    FITCITY
                </h1>
            </div>
            <nav class="flex-1 mt-6 px-4 space-y-1 overflow-y-auto">
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg> Bảng điều khiển
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'leads' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/leads">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg> Quản lý Leads (Marketing)
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'packages' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/packages/list">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                    </svg> Quản lý Gói tập
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'branches' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/branches/list">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg> Quản lý Chi nhánh
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/users/list">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg> Quản lý Nhân sự (HR)
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'contracts' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/contracts/list">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg> Hợp đồng & Doanh Thu
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'payroll' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/payroll/summary">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg> Bảng lương & Thưởng
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'expenses' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/expenses">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg> Sổ chi nội bộ
                </a>
                <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors <%= typeof activePage !== 'undefined' && activePage === 'coupons' ? 'sidebar-active text-lime-400 bg-slate-800' : 'hover:bg-slate-800 hover:text-white' %>"
                    href="/admin/coupons">
                    <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                    </svg> Khuyến mãi & Coupon
                </a>
                <form action="/auth/logout" method="POST" id="logout-form-sidebar" class="hidden"></form>
                <div class="mt-4 pt-4 border-t border-slate-800">
                    <a class="flex items-center px-4 py-3 text-sm font-medium rounded-lg text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors cursor-pointer"
                        onclick="if(confirm('Bạn có chắc chắn muốn đăng xuất?')) document.getElementById('logout-form-sidebar').submit();">
                        <svg class="h-5 w-5 mr-3 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                        </svg> Đăng xuất
                    </a>
                </div>
            </nav>
            <div class="p-4 border-t border-slate-800 text-xs text-slate-500 text-center">
                © 2026 FITCITY SYSTEM
            </div>
        </aside>
        <!-- END: Sidebar -->

        <!-- BEGIN: Main Content Area -->
        <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- BEGIN: Top Bar -->
            <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 z-10">
                <div class="hidden md:block">
                    <h2 class="text-lg font-semibold text-gray-800">
                        <%= typeof title !=='undefined' ? title : 'Quản lý hệ thống' %>
                    </h2>
                </div>
                <div class="flex items-center gap-4">
                    <!-- Notification Bell & Dropdown -->
                    <div class="relative" x-data="{ open: false }">
                        <button id="notification-bell" @click="open = !open" class="relative p-2 text-gray-400 hover:text-lime-600 transition-colors">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                            </svg>
                            <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
                                <span class="absolute top-1 right-1 h-2 w-2 bg-red-500 rounded-full border-2 border-white"></span>
                            <% } %>
                        </button>

                        <div x-show="open" @click.away="open = false" 
                             class="absolute right-0 mt-2 w-80 bg-white border border-gray-100 rounded-xl shadow-2xl z-50 overflow-hidden">
                            <div class="p-4 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                                <span class="text-xs font-bold uppercase tracking-widest text-slate-500 font-bold">Thông báo mới</span>
                                <span class="text-[10px] bg-red-500 text-white px-2 py-0.5 rounded-full"><%= typeof notifications !== 'undefined' ? notifications.length : 0 %></span>
                            </div>
                            <div class="max-h-96 overflow-y-auto">
                                <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
                                    <% notifications.forEach(noti => { %>
                                        <a href="<%= noti.link || '#' %>" class="block p-4 hover:bg-gray-50 border-b border-gray-50 transition-all">
                                            <div class="flex gap-3">
                                                <div class="w-2 h-2 mt-1.5 rounded-full flex-shrink-0 
                                                            <%= noti.type === 'Alert' ? 'bg-red-500' : (noti.type === 'Success' ? 'bg-green-500' : (noti.type === 'Warning' ? 'bg-amber-400' : 'bg-blue-500')) %>"></div>
                                                <div>
                                                    <p class="text-xs font-bold text-gray-800"><%= noti.title %></p>
                                                    <p class="text-[11px] text-gray-500 mt-0.5 line-clamp-2"><%= noti.message %></p>
                                                    <p class="text-[9px] text-gray-400 mt-1 uppercase font-medium">Vừa xong</p>
                                                </div>
                                            </div>
                                        </a>
                                    <% }) %>
                                <% } else { %>
                                    <div class="p-8 text-center opacity-40">
                                        <p class="text-xs font-medium">Không có thông báo mới</p>
                                    </div>
                                <% } %>
                            </div>
                            <div class="p-3 bg-gray-50 text-center">
                                <a href="#" class="text-[10px] font-bold text-lime-600 uppercase tracking-widest hover:underline">Xem tất cả</a>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 pl-4 border-gray-200">
                        <span class="text-sm font-medium text-gray-700">Quản trị viên</span>
                        <div class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center text-white font-bold text-xs">AD</div>
                        <form action="/auth/logout" method="POST" id="logout-form-top" class="hidden"></form>
                        <button onclick="if(confirm('Bạn có chắc chắn muốn đăng xuất?')) document.getElementById('logout-form-top').submit();" 
                            class="p-2 text-gray-400 hover:text-red-600 transition-colors" title="Đăng xuất">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </header>
            <!-- END: Top Bar -->

            <!-- BEGIN: Page Body -->
            <div class="flex-1 overflow-y-auto p-8">
                <!-- Flash Messages -->
                <%- include('./flash') %>