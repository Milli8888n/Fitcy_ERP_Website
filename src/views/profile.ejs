<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ sơ cá nhân - FitCity</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Top Bar -->
    <header class="bg-white border-b border-gray-200 px-8 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold text-gray-800">Hồ sơ cá nhân</h1>
            <a href="javascript:history.back()" class="text-sm text-gray-500 hover:text-gray-700 font-medium">← Quay lại</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto p-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <!-- Header with Avatar -->
            <div class="bg-gradient-to-r from-slate-900 to-slate-800 px-8 py-10 text-white">
                <div class="flex items-center gap-6">
                    <div class="w-20 h-20 rounded-full bg-lime-400 flex items-center justify-center text-slate-900 text-2xl font-black shadow-lg">
                        <%= user && user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold"><%= user ? user.name : 'N/A' %></h2>
                        <span class="inline-block mt-1 px-3 py-1 bg-lime-400/20 text-lime-300 text-xs font-bold rounded-full uppercase tracking-wider">
                            <%= user ? user.role : 'N/A' %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Info Grid -->
            <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Email</label>
                    <p class="mt-1 text-gray-800 font-medium"><%= user ? user.email : 'N/A' %></p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Số điện thoại</label>
                    <p class="mt-1 text-gray-800 font-medium"><%= user && user.phone ? user.phone : 'Chưa cập nhật' %></p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Chi nhánh</label>
                    <p class="mt-1 text-gray-800 font-medium"><%= user && user.branch ? user.branch.name : 'Toàn hệ thống' %></p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Trạng thái</label>
                    <p class="mt-1">
                        <span class="inline-block px-3 py-1 text-xs font-bold rounded-full 
                            <%= user && user.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                            <%= user ? user.status : 'N/A' %>
                        </span>
                    </p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Mã nhân viên</label>
                    <p class="mt-1 text-gray-800 font-mono text-sm"><%= user ? user._id : 'N/A' %></p>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">Ngày tạo tài khoản</label>
                    <p class="mt-1 text-gray-800 font-medium">
                        <%= user && user.createdAt ? new Date(user.createdAt).toLocaleDateString('vi-VN') : 'N/A' %>
                    </p>
                </div>
            </div>

            <!-- Actions -->
            <div class="px-8 pb-8 flex gap-3">
                <button disabled class="px-5 py-2.5 bg-gray-100 text-gray-400 rounded-xl font-semibold text-sm cursor-not-allowed">
                    Đổi mật khẩu (Sắp ra mắt)
                </button>
            </div>
        </div>
    </main>
</body>
</html>
