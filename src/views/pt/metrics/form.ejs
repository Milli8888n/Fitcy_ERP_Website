<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cập nhật chỉ số - PT Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0d0d0d; color: #ffffff; }
        .text-primary { color: #ccff00; }
        .bg-primary { background-color: #ccff00; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body class="p-6 md:p-12 overflow-x-hidden">
    <header class="mb-10 flex justify-between items-start">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 rounded-2xl glass p-1">
                <img alt="Client" class="w-full h-full rounded-xl object-cover" src="<%= client.avatar %>"/>
            </div>
            <div>
                <h1 class="text-3xl font-black italic tracking-tighter uppercase"><span class="text-primary tracking-normal">CẬP NHẬT</span> INBODY</h1>
                <p class="text-slate-500 text-sm">Cập nhật chỉ số cho hội viên <span class="text-white font-bold"><%= client.name %></span></p>
            </div>
        </div>
        <a href="/pt/metrics" class="px-5 py-2 glass rounded-lg text-xs font-bold hover:bg-white/10 transition-all">Hủy bỏ</a>
    </header>

    <form method="POST" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Core Stats -->
        <article class="glass p-8 rounded-3xl space-y-6">
            <h4 class="text-xs font-black uppercase tracking-widest text-primary mb-4 border-b border-primary/20 pb-4">Chỉ số Cơ bản</h4>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Cân nặng (kg)</label>
                <input type="number" step="0.1" name="weight" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Chiều cao (cm)</label>
                <input type="number" step="1" name="height" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Body Fat (%)</label>
                <input type="number" step="0.1" name="bodyFat" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
        </article>

        <!-- Composition -->
        <article class="glass p-8 rounded-3xl space-y-6">
            <h4 class="text-xs font-black uppercase tracking-widest text-primary mb-4 border-b border-primary/20 pb-4">Thành phần Cơ thể</h4>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Lượng cơ (kg)</label>
                <input type="number" step="0.1" name="muscleMass" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Mỡ nội tạng (Level)</label>
                <input type="number" step="1" name="visceralFat" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Nước (%)</label>
                    <input type="number" step="0.1" name="water" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Protein (%)</label>
                    <input type="number" step="0.1" name="protein" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
                </div>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Khoáng chất (kg)</label>
                <input type="number" step="0.1" name="minerals" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary/50 transition-all">
            </div>
            <div class="p-6 bg-primary/5 border border-primary/10 rounded-2xl">
                <p class="text-[10px] font-bold text-primary italic uppercase">Lưu ý chuyên môn:</p>
                <p class="text-[11px] text-slate-500 leading-relaxed mt-2">Dữ liệu sẽ được vẽ thành biểu đồ Radar để khách hàng theo dõi trực quan kết quả tập luyện hàng tháng.</p>
            </div>
        </article>

        <!-- Measurements -->
        <article class="glass p-8 rounded-3xl space-y-6">
            <h4 class="text-xs font-black uppercase tracking-widest text-primary mb-4 border-b border-primary/20 pb-4">Số đo Tuyến tính (cm)</h4>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Vòng ngực</label>
                    <input type="number" step="0.5" name="chest" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Vòng eo</label>
                    <input type="number" step="0.5" name="waist" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Vòng mông</label>
                    <input type="number" step="0.5" name="hips" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Bắp tay</label>
                    <input type="number" step="0.5" name="bicep" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none">
                </div>
            </div>
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 ml-1">Ghi chú / Nhận xét PT</label>
                    <textarea name="notes" rows="3" placeholder="Lưu ý về sức khỏe, mục tiêu tháng tới..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary/50 transition-all"></textarea>
                </div>
            </div>
            <div class="pt-2">
                <button type="submit" class="w-full py-5 bg-primary text-black font-black rounded-2xl shadow-xl shadow-primary/10 uppercase tracking-tighter hover:brightness-110 active:scale-95 transition-all">
                    Lưu kết quả InBody
                </button>
            </div>
        </article>
    </form>
</body>
</html>
